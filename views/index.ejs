
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link  rel="stylesheet" href="style.css">
    <title> ALL posts </title>
</head>
<body>

  
    
    <h1> Quora posts </h1> 

    <% for( post of posts ) { %>
        <div class="post"> 
            <h3 class="user">@<%=post.username %></h3>
            <h4 class="conttent"><%= post.content %> </h4> 
             <br> <br>
            <a href="http://localhost:8080/posts/<%=post.id%>"> View Post in Details </a> 
            <br> <br>
            <a href="http://localhost:8080/posts/<%=post.id%>/edit"> Edit Post  </a>
            <br> <br>

            <form method="post" action="/posts/<%=post.id%>?_method=DELETE"> 
                <button> Delete </button>
            </form>
            
        </div>    
    </div>
        
    <% } %>
    <br>
    <br>
    <a href= "http://localhost:8080/posts/new">Create New Posts </a>

</body>
</html>

